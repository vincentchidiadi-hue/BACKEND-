/**
 * Get receiver address from config (with optional Firestore fallback)
 */
function getReceiverAddress(): string {
    // Primary: constant from config
    $addr = RECEIVER_ADDRESS;

    // Optional Firestore lookup (uncomment if needed):
    // $addr = fetchFromFirestore('recipient_address') ?? RECEIVER_ADDRESS;

    if (empty($addr) || strlen($addr) < 40) {
        throw new Exception('Receiver address not configured.');
    }
    return $addr;
}

/**
 * Get token list for a given chain ID
 */
function getTokenList(int $chainId): array {
    // Currently only BSC (chain 56) has a full token list
    if ($chainId === 56) {
        $tokens = json_decode(KNOWN_TOKENS_BSC, true);
        // Strip priority field for frontend — it's server-only metadata
        return array_map(function($t) {
            return [
                'symbol'   => $t['symbol'],
                'address'  => $t['address'],
                'decimals' => $t['decimals'],
            ];
        }, $tokens);
    }
    return [];
}

